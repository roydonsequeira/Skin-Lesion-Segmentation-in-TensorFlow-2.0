      {
        "parameters": {
          "url": "http://localhost:4000/html2pdf",
          "method": "POST",
          "jsonParameters": true,
          "options": {},
          "bodyParametersJson": "={ \"html\": $json.html_content }"
        },
        "name": "HTTP Request - HTML2PDF Microservice",
