      {
        "parameters": {
          "functionCode": "// Attach PDF binary property\\nlet pdfBase64 = $json.pdf_base64 || $json.pdf || $json.pdf_base64 || null;\\nif(!pdfBase64 && $json.body && $json.body.pdf_base64) pdfBase64 = $json.body.pdf_base64;\\nif(!pdfBase64) { throw new Error('PDF microservice did not return pdf_base64'); }\\nconst buffer = Buffer.from(pdfBase64, 'base64');\\nreturn [{ json: {}, binary: { 'data.pdf': { data: buffer.toString('base64'), mimeType: 'application/pdf', fileName: 'clinical_note.pdf' } } }];"
        },
