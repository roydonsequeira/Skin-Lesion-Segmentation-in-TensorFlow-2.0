      {
        "parameters": {
          "functionCode": "// Build HTML for PDF generation from clinical_note row\\n// We'll expect that the incoming json contains the note object (from previous insert) or we should fetch it by id if needed.\\nconst note = $json.note || {};\nconst patient = { name: $json.patient_name || '', email: $json.patient_email || '' };\nconst provider = { email: $json.provider_email || '' };\nconst html = `<!doctype html><html><head><meta charset=\\\"utf-8\\\"><title>Clinical Note</title></head><body><h1>Clinical Note Summary</h1><p><strong>Patient:</strong> ${patient.name} (${patient.email})</p><p><strong>Provider:</strong> ${provider.email}</p><h2>Summary</h2><pre>${note.summary || ''}</pre><h2>Subjective</h2><pre>${note.subjective || ''}</pre><h2>Objective</h2><pre>${note.objective || ''}</pre><h2>Assessment</h2><pre>${note.assessment || ''}</pre><h2>Plan</h2><pre>${note.plan || ''}</pre></body></html>`;\nreturn [{ json: { html_content: html, note } }];"
        },
        "name": "Function - Build HTML for PDF (post-approval)",
        "type": "n8n-nodes-base.function",
        "typeVersion": 1,
        "position": [3220, 1080]
