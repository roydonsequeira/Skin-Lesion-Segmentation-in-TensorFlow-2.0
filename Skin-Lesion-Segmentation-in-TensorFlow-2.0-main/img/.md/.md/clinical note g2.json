      },
      {
        "parameters": {
          "functionCode": "// Parse Google STT response\\nconst results = $json.results || [];\\nlet transcript = '';\\nlet speakerSegments = $json.speakerLabels || $json.parsedSpeakerLabels || [];\\nif(results.length) {\\n  for(const res of results) {\\n    if(res.alternatives && res.alternatives.length) {\\n      transcript += res.alternatives[0].transcript + ' ';\\n    }\\n  }\\n}\\nreturn [{ json: { transcript: transcript.trim(), speakerSegments } }];"
        },
        "name": "Function - Parse STT Response",
        "type": "n8n-nodes-base.function",
        "typeVersion": 1,
        "position": [1740, 700]
      },
      {
        "parameters": {
          "functionCode": "// Clean transcript\\nlet text = $json.transcript || '';\\nconst fillers = ['um','uh','you know','like','so','hmm','mm'];\\nfor (const f of fillers) {\\n  const re = new RegExp('\\\\\\\\b' + f + '\\\\\\\\b', 'gi');\\n  text = text.replace(re, '');\\n}\\ntext = text.replace(/\\\\\\\\s+/g, ' ').trim();\\nreturn [{ json: { cleaned_transcript: text, speakerSegments: $json.speakerSegments } }];"
        },
        "name": "Function - Clean / Normalize Transcript",
        "type": "n8n-nodes-base.function",
        "typeVersion": 1,
        "position": [1980, 700]
      },
      {
        "parameters": {
          "functionCode": "// Build prompt for Gemma3\\nconst patientSummary = $json.patient_summary || '';\nconst provider_email = $json.provider_email || '';\nconst transcript = $json.cleaned_transcript || '';\nconst prompt = `You are a medical scribe. Create a structured SOAP note in JSON ONLY with keys: subjective, objective, assessment, plan, summary, suggested_codes.\\nPatient Summary: ${patientSummary}\\nProvider Email: ${provider_email}\\nTranscript: ${transcript}\\nReturn JSON only.`;\nreturn [{ json: { prompt } }];"
        },
        "name": "Function - Build LLM Prompt",
        "type": "n8n-nodes-base.function",
        "typeVersion": 1,
        "position": [2220, 700]
      },
      {
        "parameters": {
          "url": "http://localhost:11434/api/generate",
          "options": {},
          "responseFormat": "json",
          "jsonParameters": true,
          "bodyParametersJson": "={\n  \"model\": \"gemma3:4b\",\n  \"prompt\": $json.prompt,\n  \"stream\": false\n}"
        },
        "name": "HTTP Request - Gemma3 (Generate SOAP Note)",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [2460, 700]
      },
      {
        "parameters": {
          "functionCode": "// Normalize Gemma output safely\\nlet note = {};\nif($json.response) {\n  try {\n    note = JSON.parse($json.response);\n  } catch (err) {\n    note.raw_llm_text = $json.response;\n    note.parsing_error = err.message;\n  }\n} else if($json[0] && $json[0].generated_text) {\n  try { note = JSON.parse($json[0].generated_text); } catch(e) { note.raw_llm_text = $json[0].generated_text; note.parsing_error = e.message; }\n}\nnote.generated_at = new Date().toISOString();\nnote.provider_email = $json.provider_email || '';\nreturn [{ json: note }];"
        },
        "name": "Function - Normalize Gemma Output",
        "type": "n8n-nodes-base.function",
        "typeVersion": 1,
        "position": [2700, 700]
