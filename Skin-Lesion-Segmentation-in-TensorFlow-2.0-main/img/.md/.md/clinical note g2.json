          "values": "={{[$items('Postgres - Verify Patient')[0].json.id || null, $json[\"appointment_id\"] || '', $json[\"provider_email\"] || '', JSON.stringify($json), $json.raw_llm_text || null, 'generated', new Date().toISOString(), false]}}"
